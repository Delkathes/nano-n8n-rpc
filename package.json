{
	"name": "n8n-nodes-nano-rpc",
	"version": "0.1.0",
	"description": "n8n community node package to execute Nano node RPC commands",
	"license": "MIT",
	"homepage": "https://github.com/Delkathes/nano-n8n-rpc",
	"keywords": [
		"n8n-community-node-package",
		"n8n",
		"nano",
		"cryptocurrency",
		"payments"
	],
	"author": {
		"name": "Delkathes",
		"email": "iamt.lessd@gmail.com"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/Delkathes/nano-n8n-rpc.git"
	},
	"scripts": {
		"build": "n8n-node build",
		"build:watch": "tsc --watch",
		"dev": "n8n-node dev",
		"lint": "n8n-node lint",
		"lint:fix": "n8n-node lint --fix",
		"release": "n8n-node release",
		"prepublishOnly": "n8n-node prerelease"
	},
	"files": [
		"dist"
	],
	"n8n": {
		"n8nNodesApiVersion": 1,
		"strict": true,
		"credentials": [
			"dist/credentials/NanoApi.credentials.js"
		],
		"nodes": [
			"dist/nodes/Nano/Nano.node.js",
			"dist/nodes/Nano/NanoTrigger.node.js"
		]
	},
	"devDependencies": {
		"@n8n/node-cli": "0.29.1",
		"@release-it-plugins/lerna-changelog": "^8.0.1",
		"@release-it/conventional-changelog": "^11.0.0",
		"eslint": "9.39.4",
		"prettier": "3.8.3",
		"release-it": "19.2.4",
		"typescript": "5.9.3"
	},
	"peerDependencies": {
		"n8n-workflow": "^2.16.0"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"eslint-plugin-n8n-nodes-base",
			"isolated-vm",
			"unrs-resolver"
		]
	}
}
